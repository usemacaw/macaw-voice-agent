# =============================================================================
# OpenVoiceAPI — Environment Configuration
# =============================================================================
# Copy to .env and adjust values

# --- WebSocket Server ---
WS_HOST=0.0.0.0
WS_PORT=8765
WS_PATH=/v1/realtime
REALTIME_API_KEY=             # Empty = no auth. Set for production.
MAX_CONNECTIONS=10

# --- ASR Provider ---
# Options: remote (gRPC), qwen (local GPU), whisper (local GPU)
ASR_PROVIDER=remote
ASR_REMOTE_TARGET=localhost:50060    # IP:PORT of stt-server
ASR_REMOTE_TIMEOUT=30.0
ASR_REMOTE_STREAMING=true
ASR_LANGUAGE=pt

# --- TTS Provider ---
# Options: remote (gRPC), qwen (local GPU), kokoro (local GPU)
TTS_PROVIDER=remote
TTS_REMOTE_TARGET=localhost:50070    # IP:PORT of tts-server
TTS_REMOTE_TIMEOUT=60.0
TTS_LANGUAGE=pt
TTS_VOICE=alloy

# --- LLM Provider ---
# Options: anthropic, openai
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.8
LLM_TIMEOUT=30.0
LLM_SYSTEM_PROMPT=You are a helpful voice assistant. Keep responses concise and natural for spoken conversation.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-xxx
# LLM_MODEL=gpt-4o

# --- VAD ---
VAD_AGGRESSIVENESS=2          # 0-3, higher = more aggressive
VAD_SILENCE_MS=200            # ms of silence to detect end of speech
VAD_PREFIX_PADDING_MS=300     # ms of audio before speech to include
VAD_MIN_SPEECH_MS=250         # minimum speech duration to process

# --- Pipeline ---
PIPELINE_SENTENCE_QUEUE_SIZE=6
PIPELINE_TTS_PREFETCH_SIZE=4
PIPELINE_MAX_SENTENCE_CHARS=150
PIPELINE_TTS_TIMEOUT=15.0
PIPELINE_SENTENCE_TIMEOUT=15.0

# --- Logging ---
LOG_LEVEL=INFO
