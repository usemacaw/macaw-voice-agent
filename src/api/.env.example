# =============================================================================
# OpenVoiceAPI — Environment Configuration
# =============================================================================
# Copy to .env and adjust values

# --- WebSocket Server ---
WS_HOST=0.0.0.0
WS_PORT=8765
WS_PATH=/v1/realtime
REALTIME_API_KEY=             # Empty = no auth. Set for production.
MAX_CONNECTIONS=10

# --- ASR Provider (gRPC) ---
ASR_PROVIDER=remote
ASR_REMOTE_TARGET=localhost:50060    # IP:PORT of stt-server
ASR_REMOTE_TIMEOUT=30.0
ASR_REMOTE_STREAMING=true
ASR_LANGUAGE=pt

# --- TTS Provider (gRPC) ---
TTS_PROVIDER=remote
TTS_REMOTE_TARGET=localhost:50070    # IP:PORT of tts-server
TTS_REMOTE_TIMEOUT=60.0
TTS_LANGUAGE=pt
TTS_VOICE=alloy

# --- LLM Provider (gRPC) ---
LLM_PROVIDER=remote
LLM_REMOTE_TARGET=localhost:50080    # IP:PORT of llm-server
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.8
LLM_TIMEOUT=30.0
LLM_SYSTEM_PROMPT=Você é uma assistente de voz prestativa e natural. Responda de forma concisa, adequada para fala. Use acentuação correta do português (você, não, é, está, cotação). NUNCA escreva sem acentos. Quando o usuário pedir informações que exijam consulta externa, chame a ferramenta diretamente — NUNCA gere texto dizendo que vai pesquisar, perguntando se quer que pesquise, ou descrevendo o que faria. Aja, não descreva.

# --- VAD ---
VAD_AGGRESSIVENESS=2          # 0-3, higher = more aggressive
VAD_SILENCE_MS=250            # ms of silence to detect end of speech
VAD_PREFIX_PADDING_MS=300     # ms of audio before speech to include
VAD_MIN_SPEECH_MS=250         # minimum speech duration to process

# --- Pipeline ---
PIPELINE_SENTENCE_QUEUE_SIZE=6
PIPELINE_TTS_PREFETCH_SIZE=4
PIPELINE_MAX_SENTENCE_CHARS=150
PIPELINE_TTS_TIMEOUT=15.0
PIPELINE_SENTENCE_TIMEOUT=15.0

# --- Logging ---
LOG_LEVEL=INFO
