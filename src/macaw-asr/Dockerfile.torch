FROM pytorch/pytorch:2.4.1-cuda12.4-cudnn9-runtime

WORKDIR /app
COPY . .

RUN pip install --no-cache-dir -e ".[whisper,qwen]" python-multipart

ENV MACAW_ASR_MODEL=whisper-small
ENV MACAW_ASR_DEVICE=cuda:0
ENV MACAW_ASR_LANGUAGE=pt

EXPOSE 8766

CMD ["macaw-asr", "serve", "--host", "0.0.0.0", "--port", "8766"]
