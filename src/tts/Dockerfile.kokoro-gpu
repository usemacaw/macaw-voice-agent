# syntax=docker/dockerfile:1.4
# =============================================================================
# Dockerfile TTS Server GPU — Kokoro-ONNX com GPU (ONNX Runtime CUDA)
# =============================================================================
# Build context: src/
#   docker build -f tts/Dockerfile.kokoro-gpu -t tts-server-kokoro-gpu .
#
# Run:
#   docker run --gpus all -p 50070:50070 tts-server-kokoro-gpu
# =============================================================================

# ---------------------------------------------------------------------------
# Stage 1: Base CUDA + Python
# ---------------------------------------------------------------------------
FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04 AS base

USER root

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-dev \
    espeak-ng \
    openssh-server \
    curl \
    wget \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /var/run/sshd \
    && ln -sf /usr/bin/python3 /usr/bin/python

WORKDIR /app

# ---------------------------------------------------------------------------
# Stage 2: Python dependencies
# ---------------------------------------------------------------------------
FROM base AS deps

# Kokoro-ONNX (installs onnxruntime CPU by default)
RUN pip install --no-cache-dir \
    "kokoro-onnx>=0.4.0" \
    "numpy>=1.24.0,<3.0.0"

# Replace CPU onnxruntime with GPU version (must be after kokoro-onnx)
RUN pip install --no-cache-dir --force-reinstall "onnxruntime-gpu>=1.18.0"

# gRPC + utils
RUN pip install --no-cache-dir \
    "grpcio>=1.78.0" \
    "grpcio-health-checking>=1.78.0" \
    "grpcio-reflection>=1.78.0" \
    "python-dotenv>=1.0.0"

# ---------------------------------------------------------------------------
# Stage 3: Application
# ---------------------------------------------------------------------------
FROM deps AS app

WORKDIR /app

# Shared modules
COPY shared/ ./shared/
COPY common/ ./common/

# TTS providers + server
COPY tts/ ./tts/

# Download Kokoro models at build time
RUN mkdir -p models/kokoro && \
    wget -q "https://github.com/thewh1teagle/kokoro-onnx/releases/download/model-files-v1.0/kokoro-v1.0.onnx" \
        -O models/kokoro/kokoro-v1.0.onnx && \
    wget -q "https://github.com/thewh1teagle/kokoro-onnx/releases/download/model-files-v1.0/voices-v1.0.bin" \
        -O models/kokoro/voices-v1.0.bin

# =============================================================================
# NVIDIA
# =============================================================================
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility

# =============================================================================
# Environment
# =============================================================================
ENV GRPC_HOST=0.0.0.0
ENV GRPC_PORT=50070
ENV LOG_LEVEL=INFO

# Kokoro config
ENV TTS_PROVIDER=kokoro
ENV TTS_LANGUAGE=pt
ENV KOKORO_MODEL_DIR=/app/models/kokoro
ENV KOKORO_VOICE=pf_dora
ENV KOKORO_SPEED=1.0
ENV KOKORO_LANG=pt-br
ENV ONNX_PROVIDER=CUDAExecutionProvider

ENV PYTHONPATH=/app

EXPOSE 50070

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
  CMD python3 -c "import grpc; ch=grpc.insecure_channel('localhost:50070'); grpc.channel_ready_future(ch).result(timeout=5)" || exit 1

ENTRYPOINT []
CMD ["python3", "-m", "tts.server"]
